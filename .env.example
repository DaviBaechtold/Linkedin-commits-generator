# ─── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
# Modelo de texto (plano gratuito sugerido: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash
# Modelo visual (sugerido: gemini-3.1-flash-image-preview)
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# Fallbacks de modelo visual (separados por vírgula)
GEMINI_IMAGE_FALLBACK_MODELS=gemini-2.5-flash-image,gemini-2.0-flash-preview-image-generation
# Tempo máximo (segundos) para aguardar retry automático em erro 429
GEMINI_RETRY_429_MAX_WAIT_SECONDS=75

# ─── Telegram ──────────────────────────────────────────────────────────────────
# Obtenha via @BotFather no Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Seu chat_id pessoal — envie /start para @userinfobot para descobrir
TELEGRAM_CHAT_ID=987654321

# ─── LinkedIn ──────────────────────────────────────────────────────────────────
# Obtidos no LinkedIn Developer Portal → seu App → Auth
LINKEDIN_CLIENT_ID=seu_client_id_aqui
LINKEDIN_CLIENT_SECRET=seu_client_secret_aqui
# Token gerado pelo linkedin_auth.py (válido por 60 dias, renovável)
LINKEDIN_ACCESS_TOKEN=AQX...
# Seu ID numérico do LinkedIn — veja como obter abaixo
LINKEDIN_PERSON_ID=

# ─── Repositórios locais ────────────────────────────────────────────────────────
# Caminhos absolutos separados por vírgula
REPO_PATHS=/home/davi/projetos/api-backend,/home/davi/projetos/mobile-app,/home/davi/projetos/dashboard-web

# Seu nome exatamente como aparece nos commits
GIT_AUTHOR_NAME=Davi

# Período de extração de commits (ex: "2 weeks ago", "1 month ago")
GIT_SINCE=2 weeks ago

# Idioma do post gerado pelo Gemini ("pt-br" ou "en")
POST_LANGUAGE=pt-br

# ─── Visual (opcional) ─────────────────────────────────────────────────────────
# Habilita geração de imagem/fluxograma por IA
ENABLE_VISUAL_ASSETS=true
# Estilo: flowchart | illustration | auto
VISUAL_ASSET_STYLE=flowchart
# Quantidade de visuais por draft (1 a 3)
VISUAL_ASSET_COUNT=1
# Envia os visuais no Telegram junto com o draft
TELEGRAM_SEND_VISUAL_ASSETS=true
# Tenta publicar com imagem no LinkedIn quando houver visual
LINKEDIN_PUBLISH_WITH_VISUAL=true
# Se falhar com imagem, publica só o texto
LINKEDIN_FALLBACK_TEXT_IF_VISUAL_FAILS=true
