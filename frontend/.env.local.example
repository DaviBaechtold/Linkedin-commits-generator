, # ============================================================
# .env.local — copie para .env.local e preencha os valores
# NUNCA commite este arquivo com valores reais
# ============================================================

# ------ Supabase ------
# Encontre em: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service Role Key — NUNCA expor ao browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ------ App ------
# URL pública do seu app (sem barra final)
# Local: http://localhost:3000
# Produção: https://seu-dominio.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------ Gemini (Google AI Studio) ------
# Crie em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
# Modelo padrão (veja opções em: https://ai.google.dev/models)
GEMINI_MODEL=gemini-2.0-flash
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation

# ------ LinkedIn OAuth ------
# Crie um app em: https://www.linkedin.com/developers/apps
# Scopes necessários: openid, profile, w_member_social
# Redirect URI: ${NEXT_PUBLIC_APP_URL}/api/auth/linkedin/callback
LINKEDIN_CLIENT_ID=77...
LINKEDIN_CLIENT_SECRET=...

# ------ Rate Limiting ------
# Número máximo de gerações por usuário por dia
DAILY_GENERATE_LIMIT=10
